# Copy/adjust these and load them into your shell before running the CLI or tests:
#   set -a; source .env.example; set +a
#
# The same root credentials are consumed by both docker-compose (to boot MinIO and
# create the bucket) and by the tpuf S3 client (to talk to MinIO over the S3 API).

# --- MinIO server root credentials (used by docker-compose) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- tpuf S3 client config (used by internal/storage/s3.go) ---
# Path-style endpoint for the local MinIO API. UsePathStyle is required for MinIO.
TPUF_S3_ENDPOINT=http://localhost:9000
TPUF_S3_ACCESS_KEY=minioadmin
TPUF_S3_SECRET_KEY=minioadmin
TPUF_BUCKET=tpuf
